{
  "manifest_version": 3,
  "name": "Shadow-Gate-VPN 🌐",
  "version": "1.0.1",
  "description": "A free, open-source proxy extension for secure browsing.",
  "permissions": [
    "proxy",
    "storage",
    "declarativeNetRequest",
    "privacy"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}